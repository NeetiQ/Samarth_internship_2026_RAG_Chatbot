```env
ENVIRONMENT=production
DEBUG=false

# TEAM A - PDF INGESTION
METADATA_PATH=Data/metadata.parquet
PDF_DIR=Data/english
OUTPUT_DIR=output
NUM_PROCESSES=4

# TEAM A - DOCUMENT CHUNKING
INPUT_FILE=documents.jsonl
OUTPUT_FILE=chunked_documents.jsonl
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TEXT_SPLITTER=RecursiveCharacterTextSplitter
LOG_LEVEL=INFO
LOG_FORMAT=json

# TEAM A - EMBEDDINGS
EMBEDDINGS_PROVIDER=sentence-transformers
EMBEDDINGS_MODEL=BAAI/bge-small-en-v1.5
EMBEDDINGS_DIMENSION=384

# TEAM A / TEAM B - VECTOR DATABASE
VECTORDB_TYPE=pgvector
VECTORDB_URL=${DATABASE_URL}
VECTORDB_INDEX_NAME=legal_chunks
VECTORDB_API_KEY=

# TEAM B - POSTGRESQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=legal_rag
DB_USER=postgres
DB_PASSWORD=admin@123
DATABASE_URL=postgresql://postgres:admin@123@localhost:5432/legal_rag
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# TEAM B - RETRIEVAL
TOP_K=5
SIMILARITY=cosine

# LLM
LLM_PROVIDER=openai
LLM_API_KEY=your_api_key_here
LLM_MODEL=gpt-4
LLM_TEMPERATURE=0.3

# OCR
OCR_PROVIDER=pytesseract
OCR_LANGUAGE=eng

# BACKEND
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# FRONTEND
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# SEARCH
TOP_K_SEARCH_RESULTS=5
RERANKER_ENABLED=true
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# SESSION
SESSION_SECRET=your_secret_key_here
SESSION_TIMEOUT=3600

# DOCUMENT PROCESSING
MAX_FILE_SIZE=100
ALLOWED_FILE_TYPES=pdf,txt,doc,docx

# CITATION
CITATION_STYLE=apa

# CORS
CORS_ORIGINS=http://localhost:3000
```