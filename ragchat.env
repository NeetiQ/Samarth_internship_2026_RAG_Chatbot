# ==========================================
# Team C (RAG Chat) Environment Variables
# ==========================================

# LLM Configuration
LLM_PROVIDER=gemini
GEMINI_API_KEY=
LLM_MODEL=gemini-2.5-flash
LLM_TEMPERATURE=0.3

# Retrieval Service
RETRIEVAL_API_URL=http://localhost:8000/api/v1/retrieve

# Response Generation
MAX_OUTPUT_TOKENS=1024
TOP_P=0.95
TOP_K=40

# Chat Configuration
CHAT_HISTORY_ENABLED=true
MAX_CHAT_HISTORY_MESSAGES=10

# Citation Configuration
ENABLE_CITATIONS=true
CITATION_STYLE=apa