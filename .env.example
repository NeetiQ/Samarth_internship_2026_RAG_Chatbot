# ==========================================
# GENERAL
# ==========================================
ENVIRONMENT=production
DEBUG=false

LOG_LEVEL=INFO
LOG_FORMAT=json

# ==========================================
# BACKEND
# ==========================================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ==========================================
# DATABASE
# ==========================================
POSTGRES_SERVER=ep-shiny-fog-atb81lrb-pooler.c-9.us-east-1.aws.neon.tech
POSTGRES_USER=neondb_owner
POSTGRES_PASSWORD=YOUR_NEON_PASSWORD
POSTGRES_DB=neondb
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://neondb_owner:YOUR_NEON_PASSWORD@ep-shiny-fog-atb81lrb-pooler.c-9.us-east-1.aws.neon.tech/neondb?ssl=require:YOUR_NEON_PASSWORD@ep-shiny-fog-atb81lrb-pooler.c-9.us-east-1.aws.neon.tech/neondb?ssl=require

# ==========================================
# STORAGE
# ==========================================
STORAGE_DIR=./data/uploads
MAX_UPLOAD_SIZE_MB=50

# ==========================================
# INGESTION & CHUNKING
# ==========================================
CHUNK_SIZE=600
CHUNK_OVERLAP=100
OCR_ENGINE=PaddleOCR
OCR_LANGUAGE=en

# ==========================================
# EMBEDDINGS & RETRIEVAL (BACKEND)
# ==========================================
EMBEDDING_MODEL_NAME=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSION=384

# HF Inference Service — hosts both /embed/* and /rerank endpoints
# RERANKER_SERVICE_URL defaults to the same base URL as EMBEDDING_SERVICE_URL
EMBEDDING_SERVICE_URL=https://your-hf-space.hf.space
EMBEDDING_SERVICE_API_KEY=your_api_key_here
RERANKER_SERVICE_URL=https://your-hf-space.hf.space
RERANKER_ENABLED=true
REQUEST_TIMEOUT=30

# Pinecone Vector DB
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX=legal_rag_index
PINECONE_NAMESPACE=default
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# ==========================================
# RETRIEVAL MODULE
# ==========================================
DB_HOST=ep-shiny-fog-atb81lrb-pooler.c-9.us-east-1.aws.neon.tech
DB_PORT=5432
DB_NAME=neondb
DB_USER=neondb_owner
DB_PASSWORD=YOUR_NEON_PASSWORD

EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
TOP_K=5
SIMILARITY=cosine

PINECONE_API_KEY=YOUR_PINECONE_API_KEY
PINECONE_INDEX_NAME=legal-rag

# ==========================================
# ==========================================
# VECTOR DATABASE (Pinecone)
# ==========================================
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=legal-rag
PINECONE_REGION=us-east-1

# ==========================================
# AUTHENTICATION (JWT)
# ==========================================
SECRET_KEY=your_secret_key_change_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ==========================================
# GEMINI
# ==========================================
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-2.5-flash
RETRIEVAL_API_URL=http://localhost:8000/api/v1/retrieval/retrieve

# ==========================================
# CHAT
# ==========================================
CHAT_HISTORY_ENABLED=true
MAX_CHAT_HISTORY_MESSAGES=10
ENABLE_CITATIONS=true
CITATION_STYLE=apa

# ==========================================
# FRONTEND
# ==========================================
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000
VITE_API_URL=http://localhost:8000
FRONTEND_PORT=3000

# ==========================================
# CORPUS SEEDING
# ==========================================
SEED_CORPUS=true
CHUNKED_DOCUMENTS_PATH=./chunked_documents.jsonl
EMBEDDED_DOCUMENTS_PATH=./embedded_documents.jsonl
GENERATE_EMBEDDINGS_ON_SEED=false
SEED_BATCH_SIZE=500
EMBEDDING_BATCH_SIZE=64
# ==========================================
# BATCH INGESTION
# ==========================================
METADATA_PATH=Data/metadata.parquet
PDF_DIR=Data/english
OUTPUT_DIR=output
NUM_PROCESSES=4
