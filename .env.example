# Backend Configuration
BACKEND_PORT=8000
BACKEND_HOST=0.0.0.0

# Frontend Configuration
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# LLM Configuration
LLM_PROVIDER=openai  # Options: openai, anthropic, huggingface
LLM_API_KEY=your_api_key_here
LLM_MODEL=gpt-4
LLM_TEMPERATURE=0.3

# Embeddings Configuration
EMBEDDINGS_PROVIDER=openai  # Options: openai, huggingface, sentence-transformers
EMBEDDINGS_MODEL=text-embedding-3-small
EMBEDDINGS_DIMENSION=1536

# Vector Database Configuration
VECTORDB_TYPE=pinecone  # Options: pinecone, weaviate, milvus, chromadb
VECTORDB_URL=your_vectordb_url
VECTORDB_API_KEY=your_vectordb_api_key
VECTORDB_INDEX_NAME=legal-rag

# OCR Configuration
OCR_PROVIDER=pytesseract  # Options: pytesseract, paddleocr, doctr
OCR_LANGUAGE=eng

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost/legal_rag
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# CORS Configuration
CORS_ORIGINS=http://localhost:3000

# Session Configuration
SESSION_SECRET=your_secret_key_here
SESSION_TIMEOUT=3600

# Document Processing
MAX_FILE_SIZE=100  # MB
ALLOWED_FILE_TYPES=pdf,txt,doc,docx

# Chunking Configuration
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Search Configuration
TOP_K_SEARCH_RESULTS=5
RERANKER_ENABLED=true
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Citation Configuration
CITATION_STYLE=apa  # Options: apa, chicago, harvard, mla

# Development
DEBUG=false
ENVIRONMENT=production  # Options: development, staging, production
