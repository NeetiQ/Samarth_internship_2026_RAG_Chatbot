# ==========================================
# GENERAL CONFIGURATION
# ==========================================
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO
LOG_FORMAT=json

# ==========================================
# BACKEND CONFIGURATION
# ==========================================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000
SESSION_SECRET=your_secret_key_here
SESSION_TIMEOUT=3600

# ==========================================
# FRONTEND CONFIGURATION
# ==========================================
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# ==========================================
# DATABASE & VECTOR STORE (PostgreSQL / PGVector)
# ==========================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=legal_rag
DB_USER=postgres
DB_PASSWORD=your_password
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/legal_rag
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
VECTORDB_TYPE=pgvector
VECTORDB_URL=${DATABASE_URL}
VECTORDB_INDEX_NAME=legal_chunks
VECTORDB_API_KEY=

# ==========================================
# LLM (GEMINI) CONFIGURATION
# ==========================================
LLM_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
LLM_MODEL=gemini-2.5-flash
LLM_TEMPERATURE=0.3
MAX_OUTPUT_TOKENS=1024
TOP_P=0.95
TOP_K=40

# ==========================================
# EMBEDDINGS & RETRIEVAL CONFIGURATION
# ==========================================
EMBEDDINGS_PROVIDER=sentence-transformers
EMBEDDINGS_MODEL=BAAI/bge-small-en-v1.5
EMBEDDINGS_DIMENSION=384
SIMILARITY=cosine
TOP_K_SEARCH_RESULTS=5
RERANKER_ENABLED=true
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RETRIEVAL_API_URL=http://localhost:8000/api/v1/retrieve

# ==========================================
# INGESTION & CHUNKING CONFIGURATION
# ==========================================
METADATA_PATH=Data/metadata.parquet
PDF_DIR=Data/english
OUTPUT_DIR=output
NUM_PROCESSES=4
INPUT_FILE=documents.jsonl
OUTPUT_FILE=chunked_documents.jsonl
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TEXT_SPLITTER=RecursiveCharacterTextSplitter
MAX_FILE_SIZE=100
ALLOWED_FILE_TYPES=pdf,txt,doc,docx
OCR_PROVIDER=pytesseract
OCR_LANGUAGE=eng

# ==========================================
# CHAT CONFIGURATION
# ==========================================
CHAT_HISTORY_ENABLED=true
MAX_CHAT_HISTORY_MESSAGES=10
ENABLE_CITATIONS=true
CITATION_STYLE=apa
