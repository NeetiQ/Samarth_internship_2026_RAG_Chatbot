# ==========================================
# GENERAL
# ==========================================
ENVIRONMENT=production
DEBUG=false

LOG_LEVEL=INFO
LOG_FORMAT=json

# ==========================================
# BACKEND
# ==========================================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ==========================================
# DATABASE
# ==========================================
POSTGRES_SERVER=ep-shiny-fog-atb81lrb-pooler.c-9.us-east-1.aws.neon.tech
POSTGRES_USER=neondb_owner
POSTGRES_PASSWORD=YOUR_NEON_PASSWORD
POSTGRES_DB=neondb
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://neondb_owner:YOUR_NEON_PASSWORD@ep-shiny-fog-atb81lrb-pooler.c-9.us-east-1.aws.neon.tech/neondb?ssl=require

# ==========================================
# STORAGE
# ==========================================
STORAGE_DIR=./data/uploads
MAX_UPLOAD_SIZE_MB=50

# ==========================================
# INGESTION & CHUNKING
# ==========================================
CHUNK_SIZE=500
CHUNK_OVERLAP=50
OCR_ENGINE=PaddleOCR
OCR_LANGUAGE=en

# ==========================================
# EMBEDDINGS & RETRIEVAL (BACKEND)
# ==========================================
EMBEDDING_MODEL_NAME=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSION=384
RETRIEVAL_TOP_K=5
RERANKER_MODEL_NAME=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_TOP_K=3

# ==========================================
# RETRIEVAL MODULE
# ==========================================
DB_HOST=ep-shiny-fog-atb81lrb-pooler.c-9.us-east-1.aws.neon.tech
DB_PORT=5432
DB_NAME=neondb
DB_USER=neondb_owner
DB_PASSWORD=YOUR_NEON_PASSWORD

EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
TOP_K=5
SIMILARITY=cosine

PINECONE_API_KEY=YOUR_PINECONE_API_KEY
PINECONE_INDEX_NAME=legal-rag

# ==========================================
# AUTHENTICATION
# ==========================================
SECRET_KEY=your_secret_key_change_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ==========================================
# GEMINI
# ==========================================
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-2.5-flash
RETRIEVAL_API_URL=http://localhost:8000/api/v1/retrieval/retrieve

# ==========================================
# CHAT
# ==========================================
CHAT_HISTORY_ENABLED=true
MAX_CHAT_HISTORY_MESSAGES=10
ENABLE_CITATIONS=true
CITATION_STYLE=apa

# ==========================================
# FRONTEND
# ==========================================
VITE_API_URL=http://localhost:8000
FRONTEND_PORT=3000

# ==========================================
# CORPUS SEEDING
# ==========================================
SEED_CORPUS=true
CHUNKED_DOCUMENTS_PATH=./chunked_documents.jsonl
EMBEDDED_DOCUMENTS_PATH=./embedded_documents.jsonl
GENERATE_EMBEDDINGS_ON_SEED=false
SEED_BATCH_SIZE=500
EMBEDDING_BATCH_SIZE=64

# ==========================================
# BATCH INGESTION
# ==========================================
METADATA_PATH=Data/metadata.parquet
PDF_DIR=Data/english
OUTPUT_DIR=output
NUM_PROCESSES=4