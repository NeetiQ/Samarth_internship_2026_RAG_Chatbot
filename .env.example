# ==========================================
# GENERAL
# ==========================================
ENVIRONMENT=production
DEBUG=false

LOG_LEVEL=INFO
LOG_FORMAT=json

# ==========================================
# BACKEND (FastAPI / pydantic-settings)
# ==========================================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ==========================================
# DATABASE
# ==========================================
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password
POSTGRES_DB=legal_rag
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://postgres:your_password@localhost:5432/legal_rag

# Storage
STORAGE_DIR=./data/uploads
MAX_UPLOAD_SIZE_MB=50

# ==========================================
# INGESTION & CHUNKING
# ==========================================
CHUNK_SIZE=600
CHUNK_OVERLAP=100
OCR_ENGINE=PaddleOCR
OCR_LANGUAGE=en

# Batch ingestion pipeline (optional / offline)
METADATA_PATH=Data/metadata.parquet
PDF_DIR=Data/english
OUTPUT_DIR=output
NUM_PROCESSES=4

# ==========================================
# EMBEDDINGS & RETRIEVAL
# ==========================================
EMBEDDING_MODEL_NAME=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSION=384
RETRIEVAL_TOP_K=5
RERANKER_MODEL_NAME=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_TOP_K=3

# ==========================================
# RETRIEVAL MODULE (retrieval/config/settings.py)
# ==========================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=legal_rag
DB_USER=postgres
DB_PASSWORD=your_password
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
TOP_K=5
SIMILARITY=cosine

# ==========================================
# VECTOR DATABASE (Pinecone)
# ==========================================
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=legal-rag
PINECONE_REGION=us-east-1

# ==========================================
# AUTHENTICATION (JWT)
# ==========================================
SECRET_KEY=your_secret_key_change_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ==========================================
# LLM — GEMINI (rag_chat + backend)
# ==========================================
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
RETRIEVAL_API_URL=http://localhost:8000/api/v1/retrieval/retrieve

# Chat & Citations
CHAT_HISTORY_ENABLED=true
MAX_CHAT_HISTORY_MESSAGES=10
ENABLE_CITATIONS=true
CITATION_STYLE=apa

# ==========================================
# FRONTEND (Vite — set at build time for Docker)
# ==========================================
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000
VITE_API_URL=http://localhost:8000

# ==========================================
# CORPUS SEEDING (deployment)
# ==========================================
SEED_CORPUS=true
CHUNKED_DOCUMENTS_PATH=./chunked_documents.jsonl
EMBEDDED_DOCUMENTS_PATH=./embedded_documents.jsonl
GENERATE_EMBEDDINGS_ON_SEED=false
SEED_BATCH_SIZE=500
EMBEDDING_BATCH_SIZE=64
